FROM --platform=linux/386 i386/debian:stable-slim

RUN apt-get update && apt-get install -y \
    xfce4-panel \
    xfdesktop4 \
    xfwm4 \
    thunar \
    xfce4-terminal \
    mousepad \
    nano \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /usr/share/doc /usr/share/man

RUN useradd -m user
ENV HOME=/home/user USER=user
WORKDIR /home/user

CMD ["/usr/bin/startxfce4"]
