FROM --platform=linux/386 i386/fedora:latest

RUN dnf -y install \
    xfwm4 \
    xfce4-panel \
    xfdesktop \
    thunar \
    xfce4-terminal \
    mousepad \
    nano \
    && dnf clean all \
    && rm -rf /var/cache/dnf /usr/share/man /usr/share/doc

RUN useradd -m user
ENV HOME=/home/user USER=user
WORKDIR /home/user

CMD ["/usr/bin/startxfce4"]
